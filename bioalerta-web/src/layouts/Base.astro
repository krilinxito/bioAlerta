---
import { readFileSync, existsSync } from 'fs';
import { resolve } from 'path';

interface Props {
  title?: string;
  description?: string;
  fullHeight?: boolean;
}
const {
  title = 'BioAlerta — Biodiversidad en Riesgo en Bolivia',
  description = 'Predicción de riesgo de extinción de especies nativas de Bolivia mediante aprendizaje automático supervisado.',
  fullHeight = false,
} = Astro.props;
const currentPath = Astro.url.pathname;

let versions: { version: string; date: string; file: string; description: string }[] = [];
try {
  const p = resolve('public/data/versions.json');
  if (existsSync(p)) versions = JSON.parse(readFileSync(p, 'utf-8'));
} catch {}
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    />
  </head>
  <body class={fullHeight ? 'overflow-hidden' : ''} style="background:var(--color-bg)">
    <!-- Navigation -->
    <nav style="
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: var(--nav-height);
      background: rgba(250,250,248,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--color-border);
      z-index: 1000;
      display: flex;
      align-items: center;
    ">
      <div class="container" style="display:flex;align-items:center;justify-content:space-between;width:100%">
        <a href="/" style="
          font-family:'Playfair Display',serif;
          font-weight:700;
          font-size:1.25rem;
          color:var(--color-text);
          letter-spacing:-0.01em;
          text-decoration:none;
          display:flex;
          align-items:center;
          gap:0.5rem;
        ">
          <span style="width:8px;height:8px;border-radius:50%;background:var(--color-accent);display:inline-block"></span>
          BioAlerta
        </a>
        <div style="display:flex;gap:2rem;align-items:center">
          {[
            { href: '/mapa', label: 'Mapa' },
            { href: '/especies', label: 'Especies' },
            { href: '/metodologia', label: 'Metodología' },
            { href: '/datos', label: 'Datos' },
          ].map(({ href, label }) => (
            <a
              href={href}
              style={`
                font-size:0.875rem;
                font-weight:${currentPath === href ? '600' : '400'};
                color:${currentPath === href ? 'var(--color-accent)' : 'var(--color-secondary)'};
                text-decoration:none;
                letter-spacing:0.01em;
                transition:color 0.2s;
              `}
            >{label}</a>
          ))}

          {versions.length > 1 && (
            <div style="display:flex;align-items:center;gap:0.5rem;border-left:1px solid var(--color-border);padding-left:1.5rem">
              <span style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-secondary)">Versión</span>
              <select
                id="global-version-select"
                title="Cambiar versión del estudio"
                style="font-size:0.78rem;padding:0.3rem 0.6rem;border:1px solid var(--color-border);border-radius:4px;background:var(--color-bg);color:var(--color-text);cursor:pointer;font-family:inherit"
              >
                {versions.map(v => (
                  <option value={v.file} data-version={v.version} title={v.description}>
                    {v.version} — {v.date}
                  </option>
                ))}
              </select>
            </div>
          )}
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main style={fullHeight ? `padding-top:var(--nav-height);height:100vh;overflow:hidden` : `padding-top:var(--nav-height)`}>
      <slot />
    </main>

    {!fullHeight && (
      <footer style="
        border-top:1px solid var(--color-border);
        padding:3rem 0;
        margin-top:4rem;
        background:var(--color-surface);
      ">
        <div class="container" style="display:flex;justify-content:space-between;align-items:flex-start;gap:2rem;flex-wrap:wrap">
          <div>
            <p style="font-family:'Playfair Display',serif;font-weight:700;color:var(--color-text);font-size:1rem;margin-bottom:0.5rem">BioAlerta</p>
            <p style="font-size:0.8rem;max-width:360px;line-height:1.6">
              Proyecto de aprendizaje automático supervisado para la predicción de riesgo de extinción de especies nativas de Bolivia.
            </p>
          </div>
          <div>
            <p style="font-size:0.75rem;color:var(--color-secondary);margin-bottom:0.25rem">Universidad Mayor de San Andrés</p>
            <p style="font-size:0.75rem;color:var(--color-secondary);margin-bottom:0.25rem">Carrera de Informática — 2026</p>
            <p style="font-size:0.75rem;color:var(--color-secondary)">Maximiliano Gómez Mallo</p>
          </div>
          <div style="text-align:right">
            <a href="/datos" style="font-size:0.75rem;color:var(--color-accent);display:block;margin-bottom:0.25rem">Fuentes de datos</a>
            <a href="/metodologia" style="font-size:0.75rem;color:var(--color-accent);display:block;margin-bottom:0.25rem">Metodología</a>
            <a href="/informe_bioalerta.pdf" target="_blank" style="font-size:0.75rem;color:var(--color-accent)">Informe PDF</a>
          </div>
        </div>
      </footer>
    )}

    <style is:global>@import "../styles/global.css";</style>

    <script>
      const VERSION_KEY = 'bioalerta_version_file';
      const sel = document.getElementById('global-version-select') as HTMLSelectElement | null;
      if (sel) {
        // Restore saved selection
        const saved = localStorage.getItem(VERSION_KEY);
        if (saved) {
          const opt = Array.from(sel.options).find(o => o.value === saved);
          if (opt) sel.value = saved;
        }

        sel.addEventListener('change', () => {
          const file = sel.value;
          const version = sel.selectedOptions[0]?.dataset.version ?? '';
          localStorage.setItem(VERSION_KEY, file);
          // Notify all listeners on this page
          window.dispatchEvent(new CustomEvent('bioalerta:version-change', {
            detail: { file, version },
          }));
        });
      }
    </script>
  </body>
</html>
