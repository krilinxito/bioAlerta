---
import Base from '../layouts/Base.astro';
import SpeciesCard from '../components/SpeciesCard.astro';
import ThreatGauge from '../components/ThreatGauge.astro';
import { SPOTLIGHT } from '../data/species_spotlight';

// Load predictions data at build time
let predictions: any[] = [];
try {
  const fs = await import('fs');
  const path = await import('path');
  const dataPath = path.resolve('public/data/species.json');
  if (fs.existsSync(dataPath)) {
    predictions = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
  }
} catch (e) {
  predictions = [];
}

// Filter out exotics and sort by prob
const nativePredictions = predictions
  .filter(p => !p.is_exotic)
  .sort((a, b) => (b.prob_threatened ?? 0) - (a.prob_threatened ?? 0));

const threatened = nativePredictions.filter(p => p.pred_threatened === 1);
const aves = threatened.filter(p => p.class === 'Aves');
const mamiferos = threatened.filter(p => p.class === 'Mammalia');

const spotlightNames = new Set(SPOTLIGHT.map(s => s.scientificName));
---
<Base title="Especies — BioAlerta" description="Galería de especies bolivianas predichas como amenazadas por el modelo">

  <!-- Header -->
  <section style="padding:5rem 0 3rem;border-bottom:1px solid var(--color-border)">
    <div class="container">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-accent);margin-bottom:1rem">Predicciones del modelo</p>
      <h1 style="margin-bottom:0.75rem;max-width:700px">Especies en riesgo de extinción</h1>
      <div class="divider"></div>
      <p style="max-width:600px;font-size:1.05rem;margin-top:0">
        El modelo Random Forest identificó <strong style="color:var(--color-threat)">{threatened.length} especies nativas</strong> como
        potencialmente amenazadas entre las 202 sin evaluación IUCN. Las probabilidades superan el umbral
        adaptativo basado en la prevalencia de clases en los datos de entrenamiento.
      </p>
    </div>
  </section>

  <!-- Summary stats -->
  <section style="background:var(--color-surface);border-bottom:1px solid var(--color-border);padding:2rem 0">
    <div class="container">
      <div style="display:flex;gap:3rem;flex-wrap:wrap">
        <div>
          <p style="font-size:2rem;font-weight:700;font-family:'Playfair Display',serif;color:var(--color-threat)">{threatened.length}</p>
          <p style="font-size:0.8rem;color:var(--color-secondary)">predichas amenazadas (nativas)</p>
        </div>
        <div>
          <p style="font-size:2rem;font-weight:700;font-family:'Playfair Display',serif;color:#2471A3">{aves.length}</p>
          <p style="font-size:0.8rem;color:var(--color-secondary)">aves</p>
        </div>
        <div>
          <p style="font-size:2rem;font-weight:700;font-family:'Playfair Display',serif;color:#784212">{mamiferos.length}</p>
          <p style="font-size:0.8rem;color:var(--color-secondary)">mamíferos</p>
        </div>
        <div>
          <p style="font-size:2rem;font-weight:700;font-family:'Playfair Display',serif;color:var(--color-text)">202</p>
          <p style="font-size:0.8rem;color:var(--color-secondary)">sin IUCN evaluadas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SPOTLIGHT: species with photos -->
  <section class="section">
    <div class="container">
      <h2 style="margin-bottom:0.75rem">Especies destacadas</h2>
      <div class="divider"></div>
      <p style="max-width:560px;margin-bottom:3rem">
        Estas diez especies representan los casos más urgentes, con fotografías y contexto ecológico.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:2rem">
        {SPOTLIGHT.map(sp => (
          <SpeciesCard species={sp} large={true} />
        ))}
      </div>
    </div>
  </section>

  <!-- FULL LIST: all predicted threatened (non-exotic) -->
  {nativePredictions.length > 0 && (
    <section style="background:var(--color-surface);border-top:1px solid var(--color-border)" class="section">
      <div class="container">
        <h2 style="margin-bottom:0.75rem">Lista completa de predicciones</h2>
        <div class="divider"></div>
        <p style="max-width:560px;margin-bottom:2.5rem">
          Todas las {nativePredictions.length} especies nativas sin evaluación IUCN, ordenadas por probabilidad de amenaza.
        </p>

        <div style="overflow-x:auto">
          <table style="width:100%;border-collapse:collapse;font-size:0.85rem">
            <thead>
              <tr style="border-bottom:2px solid var(--color-border)">
                <th style="text-align:left;padding:0.75rem 1rem 0.75rem 0;font-size:0.7rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-secondary)">Especie</th>
                <th style="text-align:left;padding:0.75rem 0.5rem;font-size:0.7rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-secondary)">Clase</th>
                <th style="text-align:left;padding:0.75rem 0.5rem;font-size:0.7rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-secondary)">Predicción</th>
                <th style="text-align:left;padding:0.75rem 0.5rem;min-width:200px;font-size:0.7rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-secondary)">Probabilidad</th>
              </tr>
            </thead>
            <tbody>
              {nativePredictions.map((sp, i) => (
                <tr style={`border-bottom:1px solid var(--color-border);background:${sp.pred_threatened === 1 ? 'var(--color-threat-light)' : 'transparent'}`}>
                  <td style="padding:0.75rem 1rem 0.75rem 0">
                    <span style="font-style:italic;font-weight:500;color:var(--color-text)">{sp.species}</span>
                    {spotlightNames.has(sp.species) && (
                      <span style="margin-left:0.4rem;font-size:0.65rem;background:var(--color-accent-light);color:var(--color-accent);padding:1px 5px;border-radius:2px;font-weight:600">★ Destacada</span>
                    )}
                  </td>
                  <td style="padding:0.75rem 0.5rem">
                    <span class={`badge ${sp.class === 'Aves' ? 'badge-aves' : 'badge-mammal'}`}>{sp.class}</span>
                  </td>
                  <td style="padding:0.75rem 0.5rem">
                    {sp.pred_threatened === 1
                      ? <span class="badge badge-pred">Amenazada</span>
                      : <span style="font-size:0.72rem;color:var(--color-secondary)">No amenazada</span>
                    }
                  </td>
                  <td style="padding:0.75rem 0.5rem">
                    <ThreatGauge prob={sp.prob_threatened ?? 0} showLabel={false} />
                    <span style="font-size:0.72rem;color:var(--color-secondary);margin-top:0.25rem;display:inline-block">
                      {((sp.prob_threatened ?? 0) * 100).toFixed(1)}%
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

</Base>
