---
import ThreatGauge from './ThreatGauge.astro';
import type { SpotlightSpecies } from '../data/species_spotlight';
import { toSlug } from '../data/species_spotlight';

interface Props {
  species: SpotlightSpecies;
  large?: boolean;
}
const { species, large = false } = Astro.props;
const detailHref = `/especies/${toSlug(species.scientificName)}`;

const iucnLabel = species.iucn ?? 'Sin eval.';
const iucnClass = species.iucn
  ? `badge-${species.iucn.toLowerCase()}`
  : 'badge-pred';

const classLabel = species.class === 'Aves' ? 'Ave' : 'Mamífero';
const classBadge = species.class === 'Aves' ? 'badge-aves' : 'badge-mammal';
---
<article style={`
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 2px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.2s ease, transform 0.2s ease;
  position: relative;
`}
  onmouseenter="this.style.boxShadow='0 8px 32px rgba(0,0,0,0.10)';this.style.transform='translateY(-2px)'"
  onmouseleave="this.style.boxShadow='none';this.style.transform='translateY(0)'"
>
  <a href={detailHref} style="position:absolute;inset:0;z-index:1" aria-label={`Ver ficha de ${species.scientificName}`}></a>
  <!-- Photo -->
  <div style={`
    width:100%;
    aspect-ratio: ${large ? '16/9' : '4/3'};
    overflow:hidden;
    background: var(--color-border);
    position: relative;
  `}>
    {species.photo ? (
      <img
        src={species.photo}
        alt={species.scientificName}
        loading="lazy"
        style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease"
        onmouseenter="this.style.transform='scale(1.04)'"
        onmouseleave="this.style.transform='scale(1)'"
      />
    ) : (
      <div style={`
        width:100%;height:100%;
        background: linear-gradient(135deg, var(--color-threat-light), var(--color-border));
        display:flex;align-items:center;justify-content:center;
      `}>
        <span style="font-size:3rem;opacity:0.3">{species.class === 'Aves' ? '🦅' : '🐾'}</span>
      </div>
    )}
    <!-- Probability badge overlay -->
    <div style="position:absolute;top:0.75rem;right:0.75rem;display:flex;gap:0.4rem">
      <span class={`badge ${iucnClass}`}>{iucnLabel}</span>
    </div>
  </div>

  <!-- Content -->
  <div style="padding:1.25rem 1.25rem 1.5rem;flex:1;display:flex;flex-direction:column;gap:0.75rem">
    <div>
      <p style="font-size:0.7rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-secondary);margin-bottom:0.25rem">
        <span class={`badge ${classBadge}`} style="margin-right:0.4rem">{classLabel}</span>
      </p>
      <h3 style="font-size:1rem;font-weight:600;font-style:italic;color:var(--color-text);font-family:'Playfair Display',serif;line-height:1.3">
        {species.scientificName}
      </h3>
      <p style="font-size:0.875rem;color:var(--color-secondary);margin-top:0.2rem">{species.commonNameEs}</p>
    </div>

    {large && (
      <p style="font-size:0.875rem;color:var(--color-secondary);line-height:1.6;flex:1">
        {species.description}
      </p>
    )}

    <ThreatGauge prob={species.probThreatened} />

    {large && species.threats.length > 0 && (
      <div style="margin-top:0.25rem">
        <p style="font-size:0.7rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-secondary);margin-bottom:0.5rem">Amenazas</p>
        <ul style="list-style:none;display:flex;flex-wrap:wrap;gap:0.4rem">
          {species.threats.map(t => (
            <li style="font-size:0.75rem;background:var(--color-threat-light);color:var(--color-threat);padding:0.2rem 0.5rem;border-radius:2px">{t}</li>
          ))}
        </ul>
      </div>
    )}

    <div style="margin-top:auto;padding-top:0.75rem">
      <span style="font-size:0.72rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-accent)">
        Ver ficha →
      </span>
    </div>
  </div>
</article>
