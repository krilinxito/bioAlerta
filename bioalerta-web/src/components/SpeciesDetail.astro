---
import ThreatGauge from './ThreatGauge.astro';
import type { SpotlightSpecies } from '../data/species_spotlight';
import { toSlug } from '../data/species_spotlight';

interface Props {
  species: SpotlightSpecies;
  prev: SpotlightSpecies | null;
  next: SpotlightSpecies | null;
}

const { species, prev, next } = Astro.props;

const iucnLabel   = species.iucn ?? 'Sin eval. IUCN';
const iucnClass   = species.iucn ? `badge-${species.iucn.toLowerCase()}` : 'badge-pred';
const classLabel  = species.class === 'Aves' ? 'Ave' : 'Mamífero';
const classBadge  = species.class === 'Aves' ? 'badge-aves' : 'badge-mammal';
const pct         = Math.round(species.probThreatened * 100);
const riskLabel   = species.probThreatened > 0.15 ? 'Alto riesgo' : species.probThreatened > 0.05 ? 'Riesgo medio' : 'Bajo riesgo';
const riskColor   = species.probThreatened > 0.15 ? 'var(--color-threat)' : species.probThreatened > 0.05 ? 'var(--color-threat-low)' : 'var(--color-accent)';
const riskBg      = species.probThreatened > 0.15 ? 'var(--color-threat-light)' : species.probThreatened > 0.05 ? 'var(--color-threat-low-light)' : 'var(--color-accent-light)';

const coordLabel  = `${Math.abs(species.lat).toFixed(1)}° ${species.lat < 0 ? 'S' : 'N'}, ${Math.abs(species.lon).toFixed(1)}° ${species.lon < 0 ? 'O' : 'E'}`;
---

<!-- Back nav -->
<div style="padding:1.25rem 0;border-bottom:1px solid var(--color-border)">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
    <a
      href="/especies"
      style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.8rem;font-weight:600;color:var(--color-secondary);text-decoration:none;letter-spacing:0.04em;text-transform:uppercase"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Todas las especies
    </a>

    <!-- Prev / Next -->
    <div style="display:flex;gap:0.5rem">
      {prev && (
        <a
          href={`/especies/${toSlug(prev.scientificName)}`}
          title={prev.scientificName}
          style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.78rem;color:var(--color-secondary);text-decoration:none;padding:0.4rem 0.8rem;border:1px solid var(--color-border);border-radius:2px;transition:border-color 0.15s"
          onmouseenter="this.style.borderColor='var(--color-text)'"
          onmouseleave="this.style.borderColor='var(--color-border)'"
        >
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Anterior
        </a>
      )}
      {next && (
        <a
          href={`/especies/${toSlug(next.scientificName)}`}
          title={next.scientificName}
          style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.78rem;color:var(--color-secondary);text-decoration:none;padding:0.4rem 0.8rem;border:1px solid var(--color-border);border-radius:2px;transition:border-color 0.15s"
          onmouseenter="this.style.borderColor='var(--color-text)'"
          onmouseleave="this.style.borderColor='var(--color-border)'"
        >
          Siguiente
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M5 2L10 7L5 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      )}
    </div>
  </div>
</div>

<!-- Hero photo -->
<div style="position:relative;height:clamp(300px,55vh,600px);overflow:hidden;background:var(--color-surface)">
  {species.photo ? (
    <img
      src={species.photo}
      alt={species.scientificName}
      style="width:100%;height:100%;object-fit:cover;object-position:center 30%"
    />
  ) : (
    <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--color-threat-light),var(--color-border));display:flex;align-items:center;justify-content:center">
      <span style="font-size:6rem;opacity:0.2">{species.class === 'Aves' ? '🦅' : '🐾'}</span>
    </div>
  )}

  <!-- Gradient overlay -->
  <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(26,26,26,0.85) 0%, rgba(26,26,26,0.3) 50%, transparent 100%)"></div>

  <!-- Name on photo -->
  <div style="position:absolute;bottom:0;left:0;right:0;padding:2.5rem clamp(1rem,4vw,3rem)">
    <div style="max-width:1200px;margin:0 auto">
      <div style="display:flex;gap:0.5rem;margin-bottom:0.75rem">
        <span class={`badge ${iucnClass}`}>{iucnLabel}</span>
        <span class={`badge ${classBadge}`}>{classLabel}</span>
      </div>
      <h1 style="color:white;font-style:italic;margin-bottom:0.35rem;text-shadow:0 2px 16px rgba(0,0,0,0.4)">
        {species.scientificName}
      </h1>
      <p style="color:rgba(255,255,255,0.8);font-size:1.15rem;font-weight:400;letter-spacing:0.01em">
        {species.commonNameEs}
      </p>
    </div>
  </div>
</div>

<!-- Body -->
<section class="section">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 340px;gap:5rem;align-items:start">

      <!-- Left: description + threats -->
      <div>
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-accent);margin-bottom:1rem">
          Sobre la especie
        </p>
        <h2 style="margin-bottom:0.75rem">{species.commonNameEs}</h2>
        <div class="divider"></div>
        <p style="font-size:1.05rem;line-height:1.8;margin-top:0;color:var(--color-secondary)">
          {species.description}
        </p>

        {species.threats.length > 0 && (
          <div style="margin-top:2.5rem">
            <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-secondary);margin-bottom:1rem">
              Principales amenazas
            </p>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:0.6rem">
              {species.threats.map((t, i) => (
                <li style="display:flex;align-items:center;gap:0.75rem;padding:0.85rem 1rem;border:1px solid var(--color-border);border-radius:2px;background:var(--color-surface)">
                  <span style={`width:24px;height:24px;border-radius:50%;background:${riskBg};color:${riskColor};display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;flex-shrink:0`}>
                    {i + 1}
                  </span>
                  <span style="font-size:0.9rem;color:var(--color-text);font-weight:500">{t}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Context note -->
        <div style="margin-top:2.5rem;padding:1.25rem;border-left:3px solid var(--color-accent);background:var(--color-accent-light)">
          <p style="font-size:0.82rem;color:var(--color-accent);font-weight:600;margin-bottom:0.35rem">
            {species.iucn ? 'Especie con evaluación IUCN' : 'Identificada por el modelo BioAlerta'}
          </p>
          <p style="font-size:0.82rem;color:var(--color-secondary)">
            {species.iucn
              ? `Categorizada como ${iucnLabel} por la Lista Roja de la IUCN. El modelo confirma su situación de riesgo con una probabilidad de amenaza del ${pct}%.`
              : `Sin evaluación formal de la IUCN al momento del análisis. El modelo Random Forest predice un ${pct}% de probabilidad de amenaza basándose en rasgos biológicos, distribución y factores ambientales.`
            }
          </p>
        </div>
      </div>

      <!-- Right: stats sidebar -->
      <aside>
        <!-- Risk gauge card -->
        <div style="padding:1.5rem;border:1px solid var(--color-border);border-radius:2px;background:var(--color-surface);margin-bottom:1rem">
          <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-secondary);margin-bottom:1rem">
            Predicción del modelo
          </p>
          <div style={`display:inline-flex;align-items:center;gap:0.5rem;padding:0.4rem 0.75rem;border-radius:2px;background:${riskBg};margin-bottom:1rem`}>
            <span style={`width:8px;height:8px;border-radius:50%;background:${riskColor};flex-shrink:0`}></span>
            <span style={`font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:${riskColor}`}>
              {riskLabel}
            </span>
          </div>
          <ThreatGauge prob={species.probThreatened} />
          <p style="font-size:0.75rem;color:var(--color-secondary);margin-top:0.75rem;line-height:1.5">
            Probabilidad de amenaza según Random Forest entrenado con datos de Bolivia 2000–2024.
          </p>
        </div>

        <!-- Taxonomy / classification -->
        <div style="padding:1.5rem;border:1px solid var(--color-border);border-radius:2px;background:var(--color-surface);margin-bottom:1rem">
          <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-secondary);margin-bottom:1rem">
            Clasificación
          </p>
          <dl style="display:flex;flex-direction:column;gap:0.6rem">
            {[
              { dt: 'Nombre científico', dd: species.scientificName, italic: true },
              { dt: 'Nombre común', dd: species.commonNameEs },
              { dt: 'Clase', dd: classLabel },
              { dt: 'Estado IUCN', dd: iucnLabel },
            ].map(({ dt, dd, italic }) => (
              <div style="display:flex;justify-content:space-between;align-items:baseline;gap:0.5rem;padding-bottom:0.5rem;border-bottom:1px solid var(--color-border)">
                <dt style="font-size:0.75rem;color:var(--color-secondary);flex-shrink:0">{dt}</dt>
                <dd style={`font-size:0.82rem;font-weight:500;color:var(--color-text);text-align:right;${italic ? 'font-style:italic' : ''}`}>{dd}</dd>
              </div>
            ))}
          </dl>
        </div>

        <!-- Location -->
        <div style="padding:1.5rem;border:1px solid var(--color-border);border-radius:2px;background:var(--color-surface);margin-bottom:1.5rem">
          <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-secondary);margin-bottom:1rem">
            Distribución en Bolivia
          </p>
          <p style="font-size:0.82rem;color:var(--color-secondary);margin-bottom:0.75rem">
            Centroide aproximado de registros GBIF:
          </p>
          <code style="font-size:0.85rem;font-family:'JetBrains Mono',monospace;color:var(--color-text);background:var(--color-border);padding:0.25rem 0.5rem;border-radius:2px;display:inline-block;margin-bottom:1rem">
            {coordLabel}
          </code>
          <br/>
          <a
            href="/mapa"
            style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.8rem;font-weight:600;color:var(--color-accent);text-decoration:none;letter-spacing:0.04em;text-transform:uppercase;margin-top:0.25rem"
          >
            Ver en el mapa
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M5 2L10 7L5 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- Prev / Next species cards -->
{(prev || next) && (
  <section style="background:var(--color-surface);border-top:1px solid var(--color-border);padding:3rem 0">
    <div class="container">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-secondary);margin-bottom:1.5rem">
        Más especies
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;max-width:700px">
        {prev && (
          <a
            href={`/especies/${toSlug(prev.scientificName)}`}
            style="display:flex;align-items:center;gap:1rem;padding:1.25rem;border:1px solid var(--color-border);border-radius:2px;background:var(--color-bg);text-decoration:none;transition:border-color 0.2s"
            onmouseenter="this.style.borderColor='var(--color-accent)'"
            onmouseleave="this.style.borderColor='var(--color-border)'"
          >
            {prev.photo && (
              <img src={prev.photo} alt={prev.scientificName} style="width:56px;height:56px;object-fit:cover;border-radius:2px;flex-shrink:0" />
            )}
            <div>
              <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-secondary);margin-bottom:0.2rem">← Anterior</p>
              <p style="font-size:0.875rem;font-style:italic;font-weight:600;color:var(--color-text)">{prev.scientificName}</p>
              <p style="font-size:0.78rem;color:var(--color-secondary)">{prev.commonNameEs}</p>
            </div>
          </a>
        )}
        {next && (
          <a
            href={`/especies/${toSlug(next.scientificName)}`}
            style="display:flex;align-items:center;gap:1rem;padding:1.25rem;border:1px solid var(--color-border);border-radius:2px;background:var(--color-bg);text-decoration:none;transition:border-color 0.2s;flex-direction:row-reverse;text-align:right"
            onmouseenter="this.style.borderColor='var(--color-accent)'"
            onmouseleave="this.style.borderColor='var(--color-border)'"
          >
            {next.photo && (
              <img src={next.photo} alt={next.scientificName} style="width:56px;height:56px;object-fit:cover;border-radius:2px;flex-shrink:0" />
            )}
            <div>
              <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-secondary);margin-bottom:0.2rem">Siguiente →</p>
              <p style="font-size:0.875rem;font-style:italic;font-weight:600;color:var(--color-text)">{next.scientificName}</p>
              <p style="font-size:0.78rem;color:var(--color-secondary)">{next.commonNameEs}</p>
            </div>
          </a>
        )}
      </div>
    </div>
  </section>
)}

<style>
  @media (max-width: 860px) {
    .species-body-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
